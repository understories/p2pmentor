# Arkiv Configuration
# Required: Space ID for data isolation (no fallback allowed)
SPACE_ID=testnet-devrel

# Required: Private key for server-signed writes (Phase 0)
# Format: 0x followed by 64 hex characters
ARKIV_PRIVATE_KEY=0x...

# Optional: Target network (local or kaolin)
# Default: kaolin (testnet-first)
ARKIV_TARGET=kaolin

# Optional: Custom RPC URL (overrides default for ARKIV_TARGET)
# ARKIV_RPC_URL=https://kaolin.hoodi.arkiv.network/rpc
